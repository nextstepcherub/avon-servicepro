{
  "name": "avon-servicepro-api",
  "version": "1.0.0",
  "description": "Enterprise API service for Avon ServicePro - Medical Instrument Service Management Workspace",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "client": "vite",
  "server": "cross-env PORT=3001 tsx avon-servicepro-api/src/server.ts",
  "dev": "concurrently \"npm run server\" \"npm run client\"",
  "build": "tsc",
  "start": "cross-env PORT=3001 node avon-servicepro-api/dist/server.js",
  "lint": "tsc --noEmit",
  "test": "tsx src/tests/run-all.ts",
  "verify": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "enterprise",
    "mariadb",
    "express",
    "typescript",
    "service-management",
    "kpi"
  ],
  "author": "Avon ServicePro Lead Architect",
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "prettier": "^3.5.1",
    "tsx": "^4.19.2",
    "typescript": "~5.5.4"
  }
}
